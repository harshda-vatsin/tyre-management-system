PORT=4000
# Loopback-only by default -- Nginx is the public entry point and reverse
# proxies to this port over localhost. Only change if something outside the
# VM legitimately needs to reach the backend directly.
HOST=127.0.0.1
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=8h

# FR-AL-01: alert email notifications are only sent when SMTP_HOST is set.
# Leave unset for local/dev use -- alerts still create in-app notifications
# and are logged to the console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EBTMS Alerts <alerts@ebtms.local>"
