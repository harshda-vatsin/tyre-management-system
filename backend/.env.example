PORT=4000
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=8h

# FR-AL-01: alert email notifications are only sent when SMTP_HOST is set.
# Leave unset for local/dev use -- alerts still create in-app notifications
# and are logged to the console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EBTMS Alerts <alerts@ebtms.local>"
