# Optional. Only used by the next.config.js rewrite fallback for /api/* --
# in production Nginx proxies /api/* directly to the backend so this is
# rarely needed. Defaults to http://127.0.0.1:4000 (backend's own default).
BACKEND_INTERNAL_URL=http://127.0.0.1:4000

# Port next start binds to. PM2/Nginx expect 3000; only change both together.
PORT=3000
